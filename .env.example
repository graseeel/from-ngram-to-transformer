# Application runtime
APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8000
MODEL_CONFIG_PATH=configs/default.yaml

# Supabase local defaults after `supabase start`
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=

# Server-only. Do not expose this in a browser or commit real values.
SUPABASE_SERVICE_ROLE_KEY=

# Remote project provisioning. Required by scripts/provision-supabase.ts.
SUPABASE_ACCESS_TOKEN=
SUPABASE_ORG_ID=
SUPABASE_ORG_SLUG=
SUPABASE_REGION=us-east-1
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=
SUPABASE_PROJECT_NAME=
